# Microsoft Entra app credentials
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Sender identity used by Graph /users/{EMAIL_SENDER}/sendMail
EMAIL_SENDER=sender@example.com
EMAIL_SENDER_NAME=Model Alerts

# NIU log directory
# dev:  NIU_LOG_DIR=niue_logs
NIU_LOG_DIR=niue_logs

# THREDDS endpoints and targets
NIU_THREDDS_CATALOG_URL=??
NIU_THREDDS_FILE_NAME=???

# COK log directory
# dev:  COKS_LOG_DIR=coks_logs
COKS_LOG_DIR=coks_logs
COK_THREDDS_POINTS_URL=???

# NIU_Currents (CROCO) log directory
# dev:  CROCO_NIU_LOG_DIR=croco_niue
CROCO_NIU_LOG_DIR=croco_niue
CROCO_THREDDS_CATALOG_URL=???
CROCO_THREDDS_FILE_NAME=??
